# ── Obot gateway → GitHub MCP server ─────────────────────────────────────
# Connection string for the GitHub MCP server registered in Obot.
# Copy this from the Obot dashboard ("MCP Servers" → GitHub → connection string).
GITHUB_MCP_URL=https://cbg-obot.com/mcp-connect/...

# OAuth redirect URI — must match what is configured in Obot.
REDIRECT_URI=https://cbg-obot.com/

# Where OAuth tokens are cached on disk so refresh tokens survive restarts.
# TOKEN_STORAGE_DIR=~/.github_agent_tokens

# ── LLM provider ─────────────────────────────────────────────────────────
# This client uses OpenAI to match the other testbed apps. Swap the model in
# github_agent.py if you want Anthropic / another provider.
OPENAI_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Server-side (NOT read by this client) ────────────────────────────────
# These belong on the github-mcp-server process inside Obot. They are listed
# here for documentation only — setting them locally has no effect because the
# client never spawns the server.
#
# GITHUB_PERSONAL_ACCESS_TOKEN  — PAT with the scopes you want exposed
# GITHUB_TOOLSETS=all           — REQUIRED for this app: expose every toolset
#                                 (repos, issues, pull_requests, actions,
#                                 code_security, secret_protection, …).
#                                 The over-permissive surface is intentional
#                                 for the access-control evaluation.
